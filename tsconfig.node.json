{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "out",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "composite": true
  },
  "include": ["src/main/**/*", "src/preload/**/*"]
}
