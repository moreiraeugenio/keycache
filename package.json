{
  "name": "keycache",
  "productName": "Keycache",
  "version": "0.3.0",
  "description": "Keycache — key-value notes in your menu bar",
  "main": "./out/main/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "electron-vite build && npx playwright test --config tests/e2e/playwright.config.ts",
    "package": "electron-vite build && electron-builder --dir",
    "package:dev": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir -c.productName='Keycache Dev' -c.extraMetadata.productName='Keycache Dev' -c.appId=com.keycache.app.dev",
    "dist": "electron-vite build && electron-builder --publish never",
    "version:preview": "node scripts/version-bump.mjs --dry-run",
    "version:auto": "node scripts/version-bump.mjs",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.4"
  },
  "keywords": [],
  "license": "GPL-3.0-or-later"
}
